{
  // ponytail: assets-only Worker — serves the hand-built static site, no build, no server code.
  // "directory": "." publishes the repo root; _headers/_redirects are honored natively.
  // Same working pattern as the ikad-showcase mirror.
  "name": "bennett-dyson-site",
  "compatibility_date": "2026-07-01",
  "assets": { "directory": "." }
}
