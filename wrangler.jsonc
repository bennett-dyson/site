{
  // ponytail: assets-only Worker — serves the hand-built static site, no build, no server code.
  // Serves ./public (a dedicated dir) so repo-root junk (.git, .wrangler, config) can never be published.
  // _headers/_redirects inside public/ are honored natively.
  "name": "bennett-dyson-site",
  "compatibility_date": "2026-07-01",
  "assets": { "directory": "./public" }
}
