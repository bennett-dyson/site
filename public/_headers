# Cloudflare — applied to every response.
# Public agency storefront: indexable, plus a strict CSP we can actually enforce
# because we control every asset (no CMS, no third-party embeds). Dogfoods the pitch.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; base-uri 'self'; img-src 'self' data:; style-src 'self'; script-src 'self'; font-src 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'; upgrade-insecure-requests

# Long-cache the static assets; index.html stays fresh.
/styles.css
  Cache-Control: public, max-age=604800
/brand.js
  Cache-Control: public, max-age=604800
/favicon.svg
  Cache-Control: public, max-age=604800
